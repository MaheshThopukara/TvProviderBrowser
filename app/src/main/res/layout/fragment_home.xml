<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@color/surface_bg">

    <!-- ══════════ SCREEN 1: PERMISSION ══════════ -->
    <LinearLayout
        android:id="@+id/permissionScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Permission Card -->
        <LinearLayout
            android:layout_width="680dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_permission_card"
            android:elevation="16dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="80dp"
            android:paddingVertical="64dp">

            <!-- Permission Icon -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_permission_icon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔒"
                    android:textSize="44sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Permission Required"
                android:textColor="@color/on_surface"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:maxWidth="440dp"
                android:text="TvProvider Browser needs access to your TV listings data to display channels, programs, and recommendations stored on this device."
                android:textColor="@color/on_surface_variant"
                android:textSize="18sp" />

            <Button
                android:id="@+id/grantPermissionButton"
                style="@style/TvPrimaryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="🛡️  Grant TV Listings Access" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/on_surface_dim"
                android:textSize="13sp">

                <requestFocus />
            </TextView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_code_inline"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Requires READ_TV_LISTINGS permission"
                android:textColor="@color/on_surface_dim"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════ SCREEN 2: HOME ══════════ -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- ── Top Bar (reduced from 80dp to 56dp) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="48dp"
            android:paddingTop="12dp">

            <!-- App Brand -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_app_logo">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_app_logo" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="TvProvider Browser"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Meta -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="3dp"
                    android:text="API 36"
                    android:textColor="@color/secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="tv.db Inspector"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/exportAllButton"
                    style="@style/TvIconButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="20dp"
                    android:text="📤"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Hero Section ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:paddingHorizontal="48dp">

            <!-- Hero Main -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="@drawable/bg_hero_main"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingVertical="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inspect TvProvider Data"
                    android:textColor="@color/on_surface"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.3"
                    android:maxLines="2"
                    android:maxWidth="460dp"
                    android:text="Browse all tables in the Android TvProvider content provider — channels, programs, recommendations, and watch history."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Hero Stats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Stat 1: Tables -->
                <LinearLayout
                    android:id="@+id/statTables"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_stat_icon_blue">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="📊"
                            android:textSize="20sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/statTablesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="TABLES"
                            android:textAllCaps="true"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Stat 2: Columns -->
                <LinearLayout
                    android:id="@+id/statColumns"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_stat_icon_teal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="📋"
                            android:textSize="20sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/statColumnsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="152"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="TOTAL COLUMNS"
                            android:textAllCaps="true"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Stat 3: Rows/Page -->
                <LinearLayout
                    android:id="@+id/statRowsPage"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_stat_icon_warm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="💾"
                            android:textSize="20sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/statDbSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.05"
                            android:text="DB SIZE"
                            android:textAllCaps="true"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Section Header (reduced padding) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:paddingHorizontal="48dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Provider Tables"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Select a table to browse its data"
                android:textColor="@color/on_surface_dim"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ── Table Cards Row (horizontal scroll, fills remaining space) ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="48dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tableCardsRow"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />
        </HorizontalScrollView>

        <!-- ── Bottom Hint Bar (reduced padding) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="48dp"
            android:paddingBottom="12dp"
            android:paddingTop="4dp">

            <!-- Hint: Navigate -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kbd"
                    android:minWidth="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="◀ ▶"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Navigate"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Hint: Select -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kbd"
                    android:minWidth="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="OK"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Select"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Hint: Back -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kbd"
                    android:minWidth="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="↩"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Back"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
