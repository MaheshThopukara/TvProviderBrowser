<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/surface_elevated" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/surface_card_hover" />
            <stroke android:width="2dp" android:color="@color/focus_ring" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/surface_elevated" />
            <stroke android:width="2dp" android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>

