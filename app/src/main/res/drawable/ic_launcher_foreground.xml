<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Aurora foreground — Premium white TV with 3D depth
        108×108 canvas, safe zone: 33dp radius circle from center (54, 54)
        Monitor body: 52w × 34h — fits within circular safe zone
        Farthest corner (28,34) ≈ 32.8dp from center
    -->

    <!-- TV Monitor Body: white → light gray gradient (3D depth) -->
    <!-- x=28, y=34, w=52, h=34, r=6 -->
    <path android:pathData="M34,34 L74,34 Q80,34 80,40 L80,62 Q80,68 74,68 L34,68 Q28,68 28,62 L28,40 Q28,34 34,34 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="34"
                android:endX="54" android:endY="68">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFE4E8EC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top bezel rim highlight -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M34,34 L74,34 L74,35 L34,35 Z" />

    <!-- Screen interior: dark gradient -->
    <!-- x=32, y=38, w=44, h=26, r=4 -->
    <path android:pathData="M36,38 L72,38 Q76,38 76,42 L76,60 Q76,64 72,64 L36,64 Q32,64 32,60 L32,42 Q32,38 36,38 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="38"
                android:endX="54" android:endY="64">
                <item android:offset="0" android:color="#FF0F172A" />
                <item android:offset="1" android:color="#FF1E293B" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Data bar 1: Gold #EFBD6B — y=42, h=4.5, w=28 -->
    <path
        android:fillColor="#EFBD6B"
        android:pathData="M36,42 h28 a2.25,2.25 0 0,1 0,4.5 h-28 a2.25,2.25 0 0,1 0,-4.5 Z" />

    <!-- Data bar 2: Blue-white #C4DAFF @0.85 — y=50, h=4.5, w=22 -->
    <path
        android:fillColor="#C4DAFF"
        android:fillAlpha="0.85"
        android:pathData="M36,50 h22 a2.25,2.25 0 0,1 0,4.5 h-22 a2.25,2.25 0 0,1 0,-4.5 Z" />

    <!-- Data bar 3: Teal #7FCFCF — y=58, h=4.5, w=25 -->
    <path
        android:fillColor="#7FCFCF"
        android:pathData="M36,58 h25 a2.25,2.25 0 0,1 0,4.5 h-25 a2.25,2.25 0 0,1 0,-4.5 Z" />

    <!-- TV Stand: white → gray gradient -->
    <path android:pathData="M43,71 h22 a1.75,1.75 0 0,1 0,3.5 h-22 a1.75,1.75 0 0,1 0,-3.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="71"
                android:endX="54" android:endY="74.5">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFD1D5DB" />
            </gradient>
        </aapt:attr>
    </path>

</vector>

