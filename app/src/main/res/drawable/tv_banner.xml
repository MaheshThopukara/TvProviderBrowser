<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    xmlns:tools="http://schemas.android.com/tools"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180"
    tools:ignore="VectorRaster">

    <!--
        TV Banner — Aurora gradient style (matches icon design)
        320×180 viewport
        Background: 4-stop Aurora gradient (same as icon)
        Left zone: White TV monitor with gradient depth
        Right zone: White text bars
    -->

    <!-- Background: Aurora 4-stop diagonal gradient -->
    <path android:pathData="M0,0h320v180H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="320"
                android:endY="180">
                <item android:offset="0" android:color="#FF4338CA" />
                <item android:offset="0.35" android:color="#FF2563EB" />
                <item android:offset="0.7" android:color="#FF0891B2" />
                <item android:offset="1" android:color="#FF059669" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle center glow -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.08"
        android:pathData="M160,80 m-80,0 a80,80 0 1,1 160,0 a80,80 0 1,1 -160,0" />

    <!-- ═══ TV Monitor — Aurora style white frame with depth ═══ -->
    <!-- Frame outer: white→gray gradient, 80w×60h at (30,56) -->
    <path android:pathData="M34,56 L106,56 Q110,56 110,60 L110,112 Q110,116 106,116 L34,116 Q30,116 30,112 L30,60 Q30,56 34,56 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="70" android:startY="56"
                android:endX="70" android:endY="116">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFE4E8EC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Screen inner: dark gradient, 4dp inset -->
    <path android:pathData="M37,60 L103,60 Q106,60 106,63 L106,109 Q106,112 103,112 L37,112 Q34,112 34,109 L34,63 Q34,60 37,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="70" android:startY="60"
                android:endX="70" android:endY="112">
                <item android:offset="0" android:color="#FF0F172A" />
                <item android:offset="1" android:color="#FF1E293B" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Data rows inside screen (bold, Aurora palette) -->
    <!-- Gold header -->
    <path android:fillColor="#EFBD6B"
        android:pathData="M40,68 h36 a2.5,2.5 0 0,1 0,5 h-36 a2.5,2.5 0 0,1 0,-5 Z" />
    <!-- Blue-white data -->
    <path android:fillColor="#C4DAFF" android:fillAlpha="0.85"
        android:pathData="M40,77 h28 a2.5,2.5 0 0,1 0,5 h-28 a2.5,2.5 0 0,1 0,-5 Z" />
    <!-- Teal data -->
    <path android:fillColor="#7FCFCF"
        android:pathData="M40,86 h32 a2.5,2.5 0 0,1 0,5 h-32 a2.5,2.5 0 0,1 0,-5 Z" />
    <!-- Dim white -->
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.35"
        android:pathData="M40,95 h22 a2.5,2.5 0 0,1 0,5 h-22 a2.5,2.5 0 0,1 0,-5 Z" />

    <!-- TV Stand: white→gray gradient -->
    <path android:pathData="M54,120 h32 a2,2 0 0,1 0,4 h-32 a2,2 0 0,1 0,-4 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="70" android:startY="120"
                android:endX="70" android:endY="124">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFD1D5DB" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ═══ Text bars — white on gradient background ═══ -->

    <!-- "TvProvider" (large white bar) y=68..78 -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M148,68h130c2,0 2,2 2,2v6c0,2 -2,2 -2,2H148c-2,0 -2,-2 -2,-2v-6c0,-2 2,-2 2,-2z" />
    <!-- "Browser" (large white bar) y=83..93 -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M148,83h88c2,0 2,2 2,2v6c0,2 -2,2 -2,2H148c-2,0 -2,-2 -2,-2v-6c0,-2 2,-2 2,-2z" />
    <!-- Tagline (white accent) y=101..105 -->
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.6"
        android:pathData="M148,101h100c1,0 1,1 1,1v2c0,1 -1,1 -1,1H148c-1,0 -1,-1 -1,-1v-2c0,-1 1,-1 1,-1z" />
    <!-- Tagline 2 (white dimmer) y=109..113 -->
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.35"
        android:pathData="M148,109h70c1,0 1,1 1,1v2c0,1 -1,1 -1,1H148c-1,0 -1,-1 -1,-1v-2c0,-1 1,-1 1,-1z" />
</vector>

