<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Aurora foreground (ROUND variant) — compact to fit circular mask
        Circle safe zone: radius ≈33dp from center (54, 54)
        All content kept within ~27dp radius for safe margin
        Monitor: 40w × 26h
    -->

    <!-- TV Monitor Body: white → light gray gradient -->
    <!-- x=34, y=38, w=40, h=26, r=5 -->
    <path android:pathData="M39,38 L69,38 Q74,38 74,43 L74,59 Q74,64 69,64 L39,64 Q34,64 34,59 L34,43 Q34,38 39,38 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="38"
                android:endX="54" android:endY="64">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFE4E8EC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top bezel rim highlight -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M39,38 L69,38 L69,39 L39,39 Z" />

    <!-- Screen interior: dark gradient -->
    <!-- x=37, y=41, w=34, h=20, r=3 -->
    <path android:pathData="M40,41 L68,41 Q71,41 71,44 L71,58 Q71,61 68,61 L40,61 Q37,61 37,58 L37,44 Q37,41 40,41 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="41"
                android:endX="54" android:endY="61">
                <item android:offset="0" android:color="#FF0F172A" />
                <item android:offset="1" android:color="#FF1E293B" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Data bar 1: Gold — y=44, h=3.5, w=19 -->
    <path
        android:fillColor="#EFBD6B"
        android:pathData="M40,44 h19 a1.75,1.75 0 0,1 0,3.5 h-19 a1.75,1.75 0 0,1 0,-3.5 Z" />

    <!-- Data bar 2: Blue-white @0.85 — y=50, h=3.5, w=15 -->
    <path
        android:fillColor="#C4DAFF"
        android:fillAlpha="0.85"
        android:pathData="M40,50 h15 a1.75,1.75 0 0,1 0,3.5 h-15 a1.75,1.75 0 0,1 0,-3.5 Z" />

    <!-- Data bar 3: Teal — y=56, h=3.5, w=17 -->
    <path
        android:fillColor="#7FCFCF"
        android:pathData="M40,56 h17 a1.75,1.75 0 0,1 0,3.5 h-17 a1.75,1.75 0 0,1 0,-3.5 Z" />

    <!-- TV Stand: white → gray gradient -->
    <path android:pathData="M47,67 h14 a1.5,1.5 0 0,1 0,3 h-14 a1.5,1.5 0 0,1 0,-3 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="67"
                android:endX="54" android:endY="70">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFD1D5DB" />
            </gradient>
        </aapt:attr>
    </path>

</vector>

