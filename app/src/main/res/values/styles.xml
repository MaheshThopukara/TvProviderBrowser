<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Primary filled button (Google TV style) -->
    <style name="TvPrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_btn_primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingLeft">36dp</item>
        <item name="android:paddingRight">36dp</item>
    </style>

    <!-- Icon button (circular) -->
    <style name="TvIconButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_btn_icon</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">20sp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Page button -->
    <style name="TvPageButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_page_btn</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingLeft">22dp</item>
        <item name="android:paddingRight">22dp</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
